{
  "appId": "com.vaultpro.app",
  "appName": "VaultPro",
  "webDir": "www",
  "android": {
    "allowMixedContent": false,
    "backgroundColor": "#0a0e1a",
    "minWebViewVersion": 60
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "backgroundColor": "#0a0e1a",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    }
  },
  "server": {
    "androidScheme": "https"
  }
}
